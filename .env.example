# Vorlage für die Supabase-Zugangsdaten.
# Kopiere diese Datei zu `.env` und trage deine echten Werte ein.
# `.env` ist in .gitignore und wird NICHT committed.
# Bei Vite müssen Variablen mit VITE_ beginnen, damit sie im Client-Build
# ankommen — der anon-Key darf öffentlich sein (Row Level Security schützt
# die Daten in Supabase).

VITE_SUPABASE_URL=https://DEIN-PROJEKT.supabase.co
VITE_SUPABASE_ANON_KEY=dein-anon-public-key
